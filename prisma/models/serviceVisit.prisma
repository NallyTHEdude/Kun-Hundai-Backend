model ServiceVisit {
  id               String            @id @default(uuid()) @db.Uuid
  vehicleId        String            @db.Uuid
  kilometersDriven Int
  description      String
  serviceStatus    ServiceStatusEnum
  scheduledAt      DateTime          @db.Timestamptz
  createdAt        DateTime          @db.Timestamptz
  updatedAt        DateTime          @db.Timestamptz
  completedAt      DateTime?         @db.Timestamptz

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([vehicleId, scheduledAt])

  @@index([vehicleId, scheduledAt], map: "ServiceVisit_vehicle_history_idx")
  @@index([serviceStatus, scheduledAt], map: "ServiceVisit_status_filter_idx")
  @@index([scheduledAt], map: "ServiceVisit_scheduledAt_idx")
  @@index([completedAt], map: "ServiceVisit_completedAt_idx")
  @@map("ServiceVisit")
}

enum ServiceStatusEnum {
  COMPLETED
  PENDING
  CANCELLED
  IN_PROGRESS
}