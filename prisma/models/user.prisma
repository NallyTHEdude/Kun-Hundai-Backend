model User {
  id          String       @id @db.Uuid
  fullName    String
  phoneNumber String       @unique
  role        UserRoleEnum
  email       String       @unique
  createdAt   DateTime     @db.Timestamptz
  updatedAt   DateTime     @db.Timestamptz


  @@map("User")
}

enum UserRoleEnum {
  ADMIN    @map("ADMIN")
  EMPLOYEE @map("EMPLOYEE")
}
